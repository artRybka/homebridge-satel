{
  "pluginAlias": "SatelIntegra",
  "pluginType": "platform",
  "singular": true,
  "customUi": true,
  "headerDisplay": "Plugin Homebridge dla centrali alarmowej **Satel Integra** (ETHM-1 / ETHM-1 Plus).",
  "footerDisplay": "Numery stref, wejść i wyjść sprawdzisz w programie **DLOADX** → *Struktura systemu*.",
  "schema": {
    "type": "object",
    "required": ["name", "host", "port", "userCode"],
    "properties": {
      "name": {
        "title": "Nazwa platformy",
        "type": "string",
        "default": "Satel Integra"
      },
      "host": {
        "title": "Adres IP modułu ETHM",
        "type": "string",
        "format": "ipv4"
      },
      "port": {
        "title": "Port TCP",
        "type": "string",
        "default": "7094",
        "pattern": "^[0-9]{1,5}$",
        "description": "Numer portu TCP (1–65535). Domyślnie 7094."
      },
      "userCode": {
        "title": "Kod użytkownika Satel",
        "type": "string",
        "format": "password",
        "description": "Zalecane: utwórz w Satelu osobnego użytkownika z uprawnieniami tylko do potrzebnych stref i wyjść."
      },
      "integrationKey": {
        "title": "Klucz szyfrowania (opcjonalnie, tylko ETHM-1 Plus)",
        "type": "string",
        "format": "password"
      },
      "pollIntervalMs": {
        "title": "Interwał odpytywania (ms)",
        "type": "integer",
        "default": 1000,
        "minimum": 250
      },
      "autoDiscover": {
        "title": "Auto-discovery po połączeniu",
        "type": "boolean",
        "default": true,
        "description": "Po pierwszym połączeniu z centralą plugin odpytuje o nazwy partycji, wejść i wyjść i wypisuje w logu gotowy blok do wklejenia do konfiguracji. Nic nie dodaje automatycznie do HomeKit — wejścia/wyjścia dodajesz sam w Config UI X."
      },
      "partitions": {
        "title": "Strefy (partycje)",
        "type": "array",
        "items": {
          "type": "object",
          "required": ["id", "name"],
          "properties": {
            "id": {
              "title": "Numer strefy w Satelu (1–32)",
              "type": "integer",
              "minimum": 1,
              "maximum": 32
            },
            "name": {
              "title": "Nazwa w HomeKit",
              "type": "string"
            },
            "armHomeMode": {
              "title": "Tryb 'Home' (Stay)",
              "type": "integer",
              "default": 2,
              "enum": [0, 1, 2, 3]
            },
            "armNightMode": {
              "title": "Tryb 'Night'",
              "type": "integer",
              "default": 3,
              "enum": [0, 1, 2, 3]
            },
            "homekitModes": {
              "title": "Tryby widoczne w HomeKit",
              "type": "array",
              "default": ["off", "home", "night", "away"],
              "items": {
                "type": "string",
                "enum": ["off", "home", "night", "away"]
              },
              "description": "Ogranicz listę trybów widocznych w aplikacji Home. Np. jeśli nie używasz trybu Night, usuń go z listy."
            }
          }
        }
      },
      "zones": {
        "title": "Wejścia (czujki)",
        "type": "array",
        "items": {
          "type": "object",
          "required": ["id", "name", "type"],
          "properties": {
            "id": {
              "title": "Numer wejścia w Satelu (1–256)",
              "type": "integer",
              "minimum": 1,
              "maximum": 256
            },
            "name": {
              "title": "Nazwa w HomeKit",
              "type": "string"
            },
            "type": {
              "title": "Typ czujnika w HomeKit",
              "type": "string",
              "default": "motion",
              "oneOf": [
                { "title": "Ruch (MotionSensor)", "enum": ["motion"] },
                { "title": "Otwarcie (ContactSensor)", "enum": ["contact"] },
                { "title": "Dym (SmokeSensor)", "enum": ["smoke"] },
                { "title": "Zalanie (LeakSensor)", "enum": ["leak"] },
                { "title": "Tlenek węgla (COSensor)", "enum": ["co"] },
                { "title": "Obecność (OccupancySensor)", "enum": ["occupancy"] }
              ]
            },
            "invert": {
              "title": "Odwróć logikę",
              "type": "boolean",
              "default": false,
              "description": "Zaznacz, gdy w Satelu wejście jest typu NC i naruszenie oznacza stan spoczynkowy."
            }
          }
        }
      },
      "shutters": {
        "title": "Rolety",
        "type": "array",
        "items": {
          "type": "object",
          "required": ["name", "outputUp", "outputDown"],
          "properties": {
            "name": {
              "title": "Nazwa",
              "type": "string"
            },
            "outputUp": {
              "title": "Wyjście 'góra' (otwieranie)",
              "type": "integer",
              "minimum": 1,
              "maximum": 256
            },
            "outputDown": {
              "title": "Wyjście 'dół' (zamykanie)",
              "type": "integer",
              "minimum": 1,
              "maximum": 256
            },
            "travelUpSec": {
              "title": "Czas pełnego otwarcia (s)",
              "type": "integer",
              "default": 25,
              "minimum": 1,
              "maximum": 600
            },
            "travelDownSec": {
              "title": "Czas pełnego zamknięcia (s)",
              "type": "integer",
              "default": 25,
              "minimum": 1,
              "maximum": 600
            },
            "extraPulseSec": {
              "title": "Dodatkowy czas przy 0 % i 100 % (s)",
              "type": "integer",
              "default": 2,
              "minimum": 0,
              "maximum": 30,
              "description": "Dodatkowy czas dociśnięcia rolety do skrajnego położenia, gdy ustawiasz 0 % lub 100 %."
            },
            "pulseMs": {
              "title": "Długość impulsu sterującego (ms)",
              "type": "integer",
              "default": 500,
              "minimum": 0,
              "description": "Ustaw 0, jeśli wyjścia są bistabilne (Satel sam zatrzymuje roletę)."
            }
          }
        }
      },
      "switches": {
        "title": "Przełączniki (przekaźniki)",
        "type": "array",
        "items": {
          "type": "object",
          "required": ["name", "output"],
          "properties": {
            "name": {
              "title": "Nazwa",
              "type": "string"
            },
            "output": {
              "title": "Numer wyjścia w Satelu",
              "type": "integer",
              "minimum": 1,
              "maximum": 256
            },
            "mode": {
              "title": "Tryb działania",
              "type": "string",
              "default": "toggle",
              "oneOf": [
                { "title": "Bistabilny (ON/OFF)", "enum": ["toggle"] },
                { "title": "Impulsowy (chwilowy ON)", "enum": ["pulse"] }
              ]
            },
            "pulseMs": {
              "title": "Długość impulsu (ms, tylko dla trybu impulsowego)",
              "type": "integer",
              "default": 500,
              "minimum": 50
            }
          }
        }
      },
      "locks": {
        "title": "Zamki / elektrozaczepy",
        "type": "array",
        "items": {
          "type": "object",
          "required": ["name", "output"],
          "properties": {
            "name": {
              "title": "Nazwa",
              "type": "string"
            },
            "output": {
              "title": "Numer wyjścia w Satelu",
              "type": "integer",
              "minimum": 1,
              "maximum": 256
            },
            "pulseMs": {
              "title": "Długość impulsu otwierającego (ms)",
              "type": "integer",
              "default": 1500,
              "minimum": 50
            }
          }
        }
      }
    }
  },
  "layout": [
    { "type": "flex", "flex-flow": "row wrap", "items": ["host", "port"] },
    "userCode",
    { "key": "pollIntervalMs", "type": "number" }
  ]
}
