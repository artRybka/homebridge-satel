{
  "name": "homebridge-satel-integra",
  "displayName": "Satel Integra",
  "version": "0.1.0",
  "description": "Homebridge plugin for Satel Integra alarm system via ETHM-1 / ETHM-1 Plus.",
  "license": "MIT",
  "main": "dist/index.js",
  "engines": {
    "node": "^20 || ^22",
    "homebridge": "^1.8.0 || ^2.0.0-beta.0"
  },
  "scripts": {
    "build": "rimraf ./dist && tsc",
    "watch": "npm run build && npm link && nodemon",
    "lint": "eslint src/**/*.ts",
    "test": "node --test --import tsx test/unit/**/*.test.ts",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "keywords": [
    "homebridge-plugin",
    "satel",
    "integra",
    "ethm-1",
    "alarm",
    "homekit"
  ],
  "dependencies": {
    "satel-integra-integration-protocol": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "homebridge": "^1.8.0",
    "nodemon": "^3.1.0",
    "rimraf": "^5.0.5",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
