{
  "name": "homebridge-satel-integra",
  "displayName": "Satel Integra",
  "version": "0.6.1",
  "description": "Homebridge plugin for Satel Integra alarm system via ETHM-1 / ETHM-1 Plus.",
  "license": "MIT",
  "author": "artRybka",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/artRybka/homebridge-satel.git"
  },
  "bugs": {
    "url": "https://github.com/artRybka/homebridge-satel/issues"
  },
  "homepage": "https://github.com/artRybka/homebridge-satel#readme",
  "main": "dist/index.js",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": "^20 || ^22",
    "homebridge": "^1.8.0 || ^2.0.0-beta.0"
  },
  "scripts": {
    "build": "rimraf ./dist && tsc",
    "watch": "npm run build && npm link && nodemon",
    "lint": "eslint src/**/*.ts",
    "test": "tsx --test test/unit/framing.test.ts test/unit/connection.test.ts test/unit/commands.test.ts test/unit/discovery.test.ts",
    "prepare": "npm run build",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "keywords": [
    "homebridge-plugin",
    "satel",
    "integra",
    "ethm-1",
    "alarm",
    "homekit"
  ],
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^2.0.0",
    "satel-integra-integration-protocol": "^1.1.0"
  },
  "files": [
    "dist/",
    "homebridge-ui/",
    "config.schema.json",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "homebridge": "^1.8.0",
    "nodemon": "^3.1.0",
    "rimraf": "^5.0.5",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
